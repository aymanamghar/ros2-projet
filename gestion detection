# 4. THREAD TELEMETRIE
# ─────────────────────────────────────────
telemetry = {"alt": 0.0, "bat": 0, "mode": "?"}


def telemetry_thread():
    while True:
        try:
            msg = mav.recv_match(
                type=["GLOBAL_POSITION_INT", "BATTERY_STATUS", "HEARTBEAT"],
                blocking=True, timeout=1
            )
            if msg is None:
                continue
            t = msg.get_type()
            if t == "GLOBAL_POSITION_INT":
                telemetry["alt"] = msg.relative_alt / 1000.0
            elif t == "BATTERY_STATUS":
                telemetry["bat"] = msg.battery_remaining
            elif t == "HEARTBEAT":
                mode_map = {v: k for k, v in mav.mode_mapping().items()}
                telemetry["mode"] = mode_map.get(msg.custom_mode, str(msg.custom_mode))
        except Exception:
            pass


thr = threading.Thread(target=telemetry_thread, daemon=True)
thr.start()

