# 9. DESSIN SQUELETTE
# ─────────────────────────────────────────
def draw_landmarks_on_frame(frame, hand_landmarks_list):
    for hand_landmarks in hand_landmarks_list:
        proto = landmark_pb2.NormalizedLandmarkList()
        proto.landmark.extend([
            landmark_pb2.NormalizedLandmark(x=lm.x, y=lm.y, z=lm.z)
            for lm in hand_landmarks
        ])
        mp_drawing.draw_landmarks(
            frame, proto, mp_hands_connections,
            mp_drawing_styles.get_default_hand_landmarks_style(),
            mp_drawing_styles.get_default_hand_connections_style()
        )

# ─────────────────────────────────────────
# 10. HUD OVERLAY
# ─────────────────────────────────────────
def draw_hud(frame, gesture, command, color, two_hand_info):
    h, w = frame.shape[:2]
    overlay = frame.copy()
    cv2.rectangle(overlay, (0, h - 95), (w, h), (20, 20, 20), -1)
    cv2.addWeighted(overlay, 0.55, frame, 0.45, 0, frame)
    cv2.putText(frame, f"Geste   : {gesture}", (10, h - 62),
                cv2.FONT_HERSHEY_SIMPLEX, 0.65, (200, 200, 200), 1)
    cv2.putText(frame, f"Commande: {command}", (10, h - 28),
                cv2.FONT_HERSHEY_SIMPLEX, 0.9, color, 2)
    if two_hand_info:
        cv2.putText(frame, f"2M: {two_hand_info[2]}", (w // 2 - 90, h - 28),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.75, two_hand_info[3], 2)
    alt  = telemetry["alt"]
    bat  = telemetry["bat"]
    mode = telemetry["mode"]
    cv2.putText(frame, f"Alt:{alt:.1f}m  Bat:{bat}%  {mode}",
                (w - 280, 25), cv2.FONT_HERSHEY_SIMPLEX, 0.55, (0, 255, 180), 1)
    s_col = (0, 255, 180) if tracker.active else (120, 120, 120)
    cv2.putText(frame, "SUIVI:ON" if tracker.active else "SUIVI:OFF",
                (w - 100, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.55, s_col, 1)
    cv2.putText(frame, "T=suivi  D=decollage  L=land  Q=quitter",
                (10, 18), cv2.FONT_HERSHEY_SIMPLEX, 0.45, (180, 180, 180), 1)

