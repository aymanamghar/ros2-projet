cap.set(cv2.CAP_PROP_FPS, 30)
cap.set(cv2.CAP_PROP_BUFFERSIZE, 1)

print("\n" + "=" * 55)
print("  CONTROLE DRONE PAR GESTES v2.0 - MAVLink actif")
print("=" * 55)
print("  UNE MAIN :")
print("  Pouce leve      -> MONTER")
print("  Pouce baisse    -> DESCENDRE")
print("  Main ouverte    -> AVANCER")
print("  Peace           -> RECULER")
print("  Index gauche    -> GAUCHE")
print("  Index droite    -> DROITE")
print("  OK sign         -> ROTATION")
print("  Poing           -> STOP")
print()
print("  DEUX MAINS :")
print("  2 ouvertes      -> DECOLLAGE AUTO")
print("  2 poings        -> ATTERRISSAGE")
print("  2 pouces        -> DESARMEMENT")
print()
print("  CLAVIER : T=suivi  D=decollage  L=land  Q=quitter")
print("=" * 55)

last_gesture      = ""
last_gesture_time = 0
GESTURE_COOLDOWN  = 0.4

# ─────────────────────────────────────────
# 12. BOUCLE PRINCIPALE
# ─────────────────────────────────────────
while True:
    ret, frame = cap.read()
    if not ret:
        print("Erreur lecture camera")
        break

    yolo_results = yolo(frame, verbose=False)
    annotated    = yolo_results[0].plot()

    tracker.update(yolo_results)
    tracker.draw(annotated)

    rgb       = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    mp_image  = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb)
    detection = hand_landmarker.detect(mp_image)

    gesture       = "Aucun geste"
    command       = ""
    cmd_color     = (200, 200, 200)
    two_hand_info = None

    if detection.hand_landmarks:
        lm_list = detection.hand_landmarks
        draw_landmarks_on_frame(annotated, lm_list)

        if len(lm_list) >= 2:
            two_hand_info = classify_two_hands(lm_list)
            if two_hand_info:
                key, action_fn, label, col = two_hand_info
                two_hand_info = (key, action_fn, label, col)
                now = time.time()
                if key != last_gesture or now - last_gesture_time > GESTURE_COOLDOWN:
                    action_fn()
                    last_gesture      = key
                    last_gesture_time = now

        if not two_hand_info and not tracker.active:
            gesture = classify_gesture(lm_list[0])
            if gesture in GESTURE_ACTION:
                action_fn, cmd_label, col = GESTURE_ACTION[gesture]
                command   = cmd_label
                cmd_color = col
                now = time.time()
                if gesture != last_gesture or now - last_gesture_time > GESTURE_COOLDOWN:
                    action_fn()
                    last_gesture      = gesture
                    last_gesture_time = now
    else:
        stop_drone()

    draw_hud(annotated, gesture, command, cmd_color, two_hand_info)
    cv2.imshow("YOLO + Gestes drone - MAVLink", annotated)

    key = cv2.waitKey(1) & 0xFF
    if key == ord('q'):
        break
    elif key == ord('t'):
        tracker.active = not tracker.active
        print(f"Suivi personne : {'ON' if tracker.active else 'OFF'}")
    elif key == ord('d'):
        takeoff()
    elif key == ord('l'):
        land()

# ─────────────────────────────────────────
# 13. NETTOYAGE
# ─────────────────────────────────────────
stop_drone()
hand_landmarker.close()
cap.release()
cv2.destroyAllWindows()
print("Ferme proprement.")

