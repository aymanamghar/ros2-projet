# 7. CLASSIFICATION DES GESTES
# ─────────────────────────────────────────
def count_fingers(lm):
    index_up  = lm[8].y  < lm[6].y
    middle_up = lm[12].y < lm[10].y
    ring_up   = lm[16].y < lm[14].y
    pinky_up  = lm[20].y < lm[18].y
    thumb_up  = lm[4].y  < lm[3].y
    fingers   = sum([index_up, middle_up, ring_up, pinky_up])
    return thumb_up, fingers, index_up, middle_up, ring_up, pinky_up


def classify_gesture(lm):
    thumb_up, fingers, idx_up, mid_up, ring_up, pinky_up = count_fingers(lm)
    if thumb_up and fingers == 0:
        return "thumbs_up"
    if not thumb_up and fingers == 0:
        return "thumbs_down"
    if fingers >= 4:
        return "open_hand"
    if idx_up and mid_up and not ring_up and not pinky_up:
        return "peace"
    if idx_up and not mid_up and not ring_up and not pinky_up:
        return "point_left" if lm[8].x < lm[0].x else "point_right"
    dist = np.hypot(lm[4].x - lm[8].x, lm[4].y - lm[8].y)
    if dist < 0.07 and fingers >= 2:
        return "ok_sign"
    return "fist"


GESTURE_ACTION = {
    "thumbs_up":   (lambda: send_velocity(0.0,      0.0,     -SPEED_V), "MONTER",   (0, 255, 0)),
    "thumbs_down": (lambda: send_velocity(0.0,      0.0,      SPEED_V), "DESCENDRE",(0, 100, 255)),
    "open_hand":   (lambda: send_velocity(SPEED_H,  0.0,      0.0),     "AVANCER",  (255, 200, 0)),
    "peace":       (lambda: send_velocity(-SPEED_H, 0.0,      0.0),     "RECULER",  (200, 0, 255)),
    "point_left":  (lambda: send_velocity(0.0,     -SPEED_H,  0.0),     "GAUCHE",   (0, 200, 255)),
    "point_right": (lambda: send_velocity(0.0,      SPEED_H,  0.0),     "DROITE",   (255, 80, 80)),
    "ok_sign":     (lambda: send_yaw(30),                               "ROTATION", (80, 255, 200)),
    "fist":        (lambda: stop_drone(),                               "STOP",     (0, 0, 255)),
}


def classify_two_hands(lm_list):
    if len(lm_list) < 2:
        return None
    def is_open(lm):
        _, f, *_ = count_fingers(lm)
        return f >= 4
    def is_fist(lm):
        _, f, *_ = count_fingers(lm)
        return f == 0
    def thumb_only(lm):
        tu, f, *_ = count_fingers(lm)
        return tu and f == 0
    lm0, lm1 = lm_list[0], lm_list[1]
    if is_open(lm0) and is_open(lm1):
        return ("two_open",   takeoff,      "DECOLLAGE AUTO", (0, 255, 180))
    if is_fist(lm0) and is_fist(lm1):
        return ("two_fists",  land,         "ATTERRISSAGE",   (0, 0, 200))
    if thumb_only(lm0) and thumb_only(lm1):
        return ("two_thumbs", disarm_drone, "DESARMEMENT",    (255, 220, 0))
    return None

# ─────────────────────────────────────────
# 8. SUIVI DE PERSONNE
# ─────────────────────────────────────────
FRAME_W, FRAME_H = 640, 480


class PersonTracker:
    DEAD_ZONE = 60

    def __init__(self):
        self.active  = False
        self.command = ""
        self.box     = None

    def update(self, yolo_results):
        if not self.active:
            self.command = ""
            self.box = None
            return
        boxes   = yolo_results[0].boxes
        persons = [b for b in boxes if int(b.cls[0]) == 0]
        if not persons:
            self.command = "RECHERCHE..."
            self.box = None
            return
        biggest = max(persons, key=lambda b: (b.xyxy[0][2] - b.xyxy[0][0]) *
                                              (b.xyxy[0][3] - b.xyxy[0][1]))
        x1, y1, x2, y2 = map(int, biggest.xyxy[0])
        self.box = (x1, y1, x2, y2)
        cx    = (x1 + x2) // 2
        box_h = y2 - y1
        if abs(cx - FRAME_W // 2) > self.DEAD_ZONE:
            if cx > FRAME_W // 2:
                send_velocity(0.0, SPEED_H, 0.0)
                self.command = "SUIVI->DROITE"
            else:
                send_velocity(0.0, -SPEED_H, 0.0)
                self.command = "SUIVI->GAUCHE"
        elif box_h < FRAME_H * 0.35:
            send_velocity(SPEED_H, 0.0, 0.0)
            self.command = "SUIVI->AVANCER"
        elif box_h > FRAME_H * 0.75:
            send_velocity(-SPEED_H, 0.0, 0.0)
            self.command = "SUIVI->RECULER"
        else:
            stop_drone()
            self.command = "SUIVI->MAINTIEN"

    def draw(self, frame):
        if self.box:
            x1, y1, x2, y2 = self.box
            cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 180), 2)
            cv2.putText(frame, "CIBLE", (x1, y1 - 8),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 180), 2)


tracker = PersonTracker()

